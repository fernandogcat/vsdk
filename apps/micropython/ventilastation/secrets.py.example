# Per-device local config. Copy to `secrets.py` (gitignored) ONLY on a dev board you want
# to run in mirror mode — it streams the display to the vsdk emulator over WiFi instead of
# driving the POV LEDs. Real-hardware builds omit this file and run normally.
#
#   cp secrets.py.example secrets.py   # then edit the values below

MIRROR = True                 # set False (or omit secrets.py) for normal LED hardware
WIFI_SSID = "your-2.4GHz-ssid"
WIFI_PASS = "your-password"
